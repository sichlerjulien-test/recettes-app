# Supabase — exposées côté navigateur (publiques, conçues pour ça)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — clé admin SECRÈTE, jamais côté client, utilisée par les scripts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API — pour la génération de planning (Session ultérieure)
ANTHROPIC_API_KEY=sk-ant-your-api-key
